<?xml version="1.0"?>
<!--
  Top-level robot description for the teleoperation arm.

  NOTE:
  This keeps lightweight cylinder visuals so the stack runs without external
  mesh assets, but the joint origins, rotations, limits, and tool frame follow
  the Panda kinematic chain used by the MuJoCo model.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="panda">

  <!-- Args propagated from launch -->
  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="can_interface" default="vcan0"/>

  <xacro:property name="num_joints" value="7"/>

  <!-- ===== Geometry macros ===== -->
  <xacro:macro name="link_cyl" params="name length:=0.15 radius:=0.04 mass:=1.0">
    <link name="${name}">
      <visual>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${radius}" length="${length}"/></geometry>
        <material name="steel"><color rgba="0.6 0.6 0.65 1.0"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${radius}" length="${length}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ===== Kinematic tree ===== -->
  <link name="world"/>

  <xacro:link_cyl name="panda_link0" length="0.10" radius="0.06" mass="2.0"/>
  <joint name="base_fixed" type="fixed">
    <parent link="world"/>
    <child link="panda_link0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!--
    Panda kinematics matching config/models/franka_panda.xml.
    The visual geometry remains intentionally lightweight, but joint origins,
    rotations, axes, and limits must match the simulated arm so MoveIt Servo
    sees a real 7-DOF Panda instead of the old scaffold chain.
  -->
  <xacro:link_cyl name="panda_link1"/>
  <joint name="panda_joint1" type="revolute">
    <parent link="panda_link0"/>
    <child link="panda_link1"/>
    <origin xyz="0 0 0.333" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="87.0" velocity="2.62"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <xacro:link_cyl name="panda_link2"/>
  <joint name="panda_joint2" type="revolute">
    <parent link="panda_link1"/>
    <child link="panda_link2"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.7628" upper="1.7628" effort="87.0" velocity="2.62"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <xacro:link_cyl name="panda_link3"/>
  <joint name="panda_joint3" type="revolute">
    <parent link="panda_link2"/>
    <child link="panda_link3"/>
    <origin xyz="0 -0.316 0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="87.0" velocity="2.62"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <xacro:link_cyl name="panda_link4"/>
  <joint name="panda_joint4" type="revolute">
    <parent link="panda_link3"/>
    <child link="panda_link4"/>
    <origin xyz="0.0825 0 0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0718" upper="-0.0698" effort="87.0" velocity="2.62"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <xacro:link_cyl name="panda_link5"/>
  <joint name="panda_joint5" type="revolute">
    <parent link="panda_link4"/>
    <child link="panda_link5"/>
    <origin xyz="-0.0825 0.384 0" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="12.0" velocity="5.26"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <xacro:link_cyl name="panda_link6"/>
  <joint name="panda_joint6" type="revolute">
    <parent link="panda_link5"/>
    <child link="panda_link6"/>
    <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.0175" upper="3.7525" effort="12.0" velocity="4.18"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <xacro:link_cyl name="panda_link7"/>
  <joint name="panda_joint7" type="revolute">
    <parent link="panda_link6"/>
    <child link="panda_link7"/>
    <origin xyz="0.088 0 0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8973" upper="2.8973" effort="12.0" velocity="5.26"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <!-- End-effector / tool frame -->
  <link name="panda_hand"/>
  <joint name="panda_hand_joint" type="fixed">
    <parent link="panda_link${num_joints}"/>
    <child link="panda_hand"/>
    <origin xyz="0 0 0.107" rpy="0 0 -0.78539816339"/>
  </joint>
  <link name="panda_ee"/>
  <joint name="panda_ee_joint" type="fixed">
    <parent link="panda_hand"/>
    <child link="panda_ee"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <!-- ===== ros2_control hardware binding ===== -->
  <xacro:include filename="$(find teleop_description)/urdf/panda.ros2_control.xacro"/>
  <xacro:panda_ros2_control
      name="panda_canopen_system"
      num_joints="${num_joints}"
      use_sim="$(arg use_sim)"
      can_interface="$(arg can_interface)"/>

</robot>
